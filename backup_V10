            _MEM["history"] = _MEM["history"][-500:]
        _save_mem(_MEM)
    except Exception as exc:
        print(f"[MEM] History save error: {exc}")


# ── Module-level gesture singleton ────────────────────────────────────────────
_GESTURE_ENGINE: Optional["GestureEngine"] = None


def process_input(text: str) -> str:
    text = text.strip()
    if not text:
        return "I didn't catch that. Could you repeat?"
    tl = text.lower()

    # Gesture engine voice control
    if re.search(r'\bactivate\s+hand\b|\bhand\s+(control|gesture)\b'
                 r'|\bstart\s+gesture\b|\bgesture\s+on\b', tl):
        if _GESTURE_ENGINE is not None:
            _GESTURE_ENGINE.set_active(True)
            result = ("Hand gesture control activated! "
                      "Show your hand to the camera. "
                      "Pinch for click, fist for screenshot.")
        else:
            result = "Gesture engine is not initialised."
        speak(result)
        _save_mem_entry(text, result); _HIST.log(text, result, "gesture")
        return result

    if re.search(r'\bdeactivate\b|\bhand\s+(control\s+off|gesture\s+off)\b'
                 r'|\bstop\s+gesture\b|\bgesture\s+off\b', tl):
        if _GESTURE_ENGINE is not None:
            _GESTURE_ENGINE.set_active(False)
        result = "Hand gesture control deactivated."
        speak(result)
        _save_mem_entry(text, result); _HIST.log(text, result, "gesture")
        return result

    if _PENDING_STATE:
        result = _handle_pending(text)
        _save_mem_entry(text, result); _HIST.log(text, result, "pending")
        return result

    if tl.strip() == "apis" or tl.startswith("apis ") or tl.startswith("apir"):
        result = _handle_api_command(text)
        _save_mem_entry(text, result); _HIST.log(text, result, "api_manage")
        return result

    if re.search(r"\b(time|baje|ghante)\b", tl) and not _is_math(tl):
        result = cmd_datetime("time")
        _save_mem_entry(text, result); _HIST.log(text, result, "date_time")
        return result
    if re.search(r"\b(date|tarikh)\b", tl) and not _is_math(tl):
        result = cmd_datetime("date")
        _save_mem_entry(text, result); _HIST.log(text, result, "date_time")
        return result
    if re.search(r"\b(aaj\s+ka\s+din|weekday|day\s+today|today.*day)\b", tl):
        result = cmd_datetime("day")
        _save_mem_entry(text, result); _HIST.log(text, result, "date_time")
        return result

    if _is_math(tl):
        expr   = _strip(tl, ["what is", "calculate", "solve", "compute", "find"])
        result = cmd_solve_math(expr or text)
        _save_mem_entry(text, result); _HIST.log(text, result, "math")
        return result

    reply = _rule_reply(text)
    if reply:
        speak(reply)
        _save_mem_entry(text, reply); _HIST.log(text, reply, "chat")
        return reply

    intent = classify_intent(text)
    if intent != "chat":
        result = execute_command(text, intent)
        if result:
            _save_mem_entry(text, result); _HIST.log(text, result, intent)
            return result

    all_keys = list(APPS.keys()) + list(SETTINGS_MAP.keys())
    m = get_close_matches(tl, all_keys, n=1, cutoff=0.52)
    if m:
        k = m[0]
        if k in APPS:
            _popen_silent(APPS[k]); result = f"Opening {k}."
        else:
            _popen_silent(f"start {SETTINGS_MAP[k]}"); result = f"Opening {k} settings."
        speak(result)
        _save_mem_entry(text, result); _HIST.log(text, result, "open_app")
        return result

    if _LOCAL_AI.available:
        history  = _build_ollama_history(n=8)
        ai_reply = _LOCAL_AI.ask(text, history)
        if ai_reply:
            _save_mem_entry(text, ai_reply)
            _HIST.log(text, ai_reply, "ollama")
            speak(ai_reply)
            return ai_reply

    has_pc = any(w in tl for w in _PC_WORDS)
    has_q  = any(w in tl for w in ("what", "who", "how", "why", "when",
                                     "where", "which", "kya", "kaun"))
    if has_q and not has_pc:
        result = cmd_web_search(text)
        _save_mem_entry(text, result); _HIST.log(text, result, "web_search")
        return result

    result = random.choice([
        "I'm not sure how to help with that. Could you rephrase?",
        "Could you be more specific? I want to assist you correctly.",
        "Try: 'open Chrome', 'what time is it', 'weather', "
        "'latest news', 'my ram', or 'calculate 5+3'.",
    ])
    _save_mem_entry(text, result); _HIST.log(text, result, "unknown")
    return result



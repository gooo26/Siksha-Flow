#  §10  GESTURE ENGINE — MediaPipe hand tracking (QThread, headless)
# ══════════════════════════════════════════════════════════════════════════════

class GestureEngine(QThread):
    gesture_detected = pyqtSignal(str)

    _PINCH_THRESH  = 0.055
    _SCROLL_THRESH = 0.058
    _VOL_MOVE_MIN  = 0.025
    _VOL_DELTA_MIN = 0.012
    _SCROLL_DELTA  = 0.018
    _FPS_CAP       = 0.033

    def __init__(self):
        super().__init__()
        self.setObjectName("ISHA-GestureEngine")
        self.setTerminationEnabled(True)
        self._active  = False
        self._running = False

    def set_active(self, on: bool):
        self._active = on

    def stop_engine(self):
        self._running = False
        self._active  = False

    @staticmethod
    def _dist(lm, a: int, b: int) -> float:
        dx = lm[a].x - lm[b].x
        dy = lm[a].y - lm[b].y
        return (dx * dx + dy * dy) ** 0.5

    @staticmethod
    def _cooldown_ok(cd: dict, key: str, gap: float) -> bool:
        now = time.monotonic()
        if now - cd.get(key, 0.0) >= gap:
            cd[key] = now
            return True
        return False

    def run(self):
        try:
            import cv2, mediapipe as mp
        except ImportError as exc:
            self.gesture_detected.emit(
                f"__error__:Gesture engine unavailable — {exc}.")
            return
        mp_hands = mp.solutions.hands
        THUMB = 4; INDEX = 8; MIDDLE = 12; RING = 16; PINKY = 20
        I_MCP = 5; M_MCP = 9; R_MCP = 13; P_MCP = 17
        _d   = self._dist
        _cok = self._cooldown_ok
        self._running = True
        cap:   Any               = None
        cd:    Dict[str, float]  = {}
        pinch_frames = 0
        pinch_start_x: Optional[float]  = None
        prev_pinch_x:  Optional[float]  = None
        vol_fired_this_pinch = False
        prev_scroll_y: Optional[float]  = None

        with mp_hands.Hands(
            model_complexity=0,
            min_detection_confidence=0.70,
            min_tracking_confidence=0.60,
            max_num_hands=1,
            static_image_mode=False,
        ) as hands:
            while self._running:
                if not self._active:
                    if cap is not None:
                        cap.release(); cap = None
                    pinch_frames = 0
                    pinch_start_x = prev_pinch_x = prev_scroll_y = None
                    vol_fired_this_pinch = False
                    time.sleep(0.15)
                    continue
                if cap is None or not cap.isOpened():
                    cap = cv2.VideoCapture(0)
                    if not cap.isOpened():
                        self.gesture_detected.emit(
                            "__error__:Webcam unavailable.")
                        self._active = False; cap = None; continue
                ret, frame = cap.read()
                if not ret:
                    time.sleep(0.04); continue
                rgb = cv2.cvtColor(frame, cv2.COLOR_BGR2RGB)
                rgb.flags.writeable = False
                results = hands.process(rgb)
                if not results.multi_hand_landmarks:
                    if pinch_frames > 0 and not vol_fired_this_pinch:
                        if _cok(cd, "left_click", 0.55):
                            self.gesture_detected.emit("left_click")
                    pinch_frames = 0
                    pinch_start_x = prev_pinch_x = prev_scroll_y = None
                    vol_fired_this_pinch = False
                    time.sleep(self._FPS_CAP); continue
                lm     = results.multi_hand_landmarks[0].landmark
                d_ti   = _d(lm, THUMB, INDEX)
                d_tm   = _d(lm, THUMB, MIDDLE)
                d_im   = _d(lm, INDEX, MIDDLE)
                pinch_now = d_ti < self._PINCH_THRESH
                if pinch_now:
                    pinch_frames += 1
                    cur_x = lm[INDEX].x
                    if pinch_start_x is None:
                        pinch_start_x = cur_x
                    total_dx = cur_x - pinch_start_x
                    if abs(total_dx) > self._VOL_MOVE_MIN:
                        if prev_pinch_x is not None:
                            delta = cur_x - prev_pinch_x
                            if abs(delta) > self._VOL_DELTA_MIN and _cok(cd, "volume", 0.22):
                                self.gesture_detected.emit(
                                    "volume_up" if delta > 0 else "volume_down")
                        vol_fired_this_pinch = True
                    prev_pinch_x = cur_x
                else:
                    if pinch_frames > 0:
                        if not vol_fired_this_pinch and _cok(cd, "left_click", 0.55):
                            self.gesture_detected.emit("left_click")
                    pinch_frames = 0
                    pinch_start_x = prev_pinch_x = None
                    vol_fired_this_pinch = False
                if d_tm < self._PINCH_THRESH and d_ti > self._PINCH_THRESH:
                    if _cok(cd, "right_click", 0.70):
                        self.gesture_detected.emit("right_click")
                index_up  = lm[INDEX].y  < lm[I_MCP].y - 0.04
                middle_up = lm[MIDDLE].y < lm[M_MCP].y - 0.04
                if index_up and middle_up and d_im < self._SCROLL_THRESH:
                    cur_y = lm[INDEX].y
                    if prev_scroll_y is not None:
                        delta_y = cur_y - prev_scroll_y
                        if abs(delta_y) > self._SCROLL_DELTA and _cok(cd, "scroll", 0.14):
                            clicks = -4 if delta_y < 0 else 4
                            self.gesture_detected.emit(f"scroll:{clicks}")
                    prev_scroll_y = cur_y
                else:
                    prev_scroll_y = None
                fist = (
                    lm[INDEX].y  > lm[I_MCP].y  + 0.02 and
                    lm[MIDDLE].y > lm[M_MCP].y  + 0.02 and
                    lm[RING].y   > lm[R_MCP].y  + 0.02 and
                    lm[PINKY].y  > lm[P_MCP].y  + 0.02
                )
                if fist and _cok(cd, "screenshot", 3.5):
                    self.gesture_detected.emit("screenshot")
                time.sleep(self._FPS_CAP)
        if cap is not None:
            cap.release()



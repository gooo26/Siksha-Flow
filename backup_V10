_MATH_SAFE_RE = re.compile(r"^[\s0-9\.\+\-\*\/\%\(\)\^epi]+$")


def cmd_solve_math(raw: str) -> str:
    expr = raw.strip()
    if not expr:
        result = "Please give me a math expression to solve."
        speak(result); return result
    cleaned = (expr
               .replace("×", "*").replace("÷", "/").replace("^", "**")
               .replace("√", "sqrt(").replace("π", "pi")
               .replace("plus", " + ").replace("minus", " - ")
               .replace("times", " * ").replace("multiplied by", " * ")
               .replace("divided by", " / ").replace("power of", "**")
               .replace("percent of", "*0.01*").replace("and", "+"))
    cleaned = re.sub(r"(?<![a-zA-Z])x(?![a-zA-Z])", "*", cleaned)
    opens, closes = cleaned.count("("), cleaned.count(")")
    if opens > closes:
        cleaned += ")" * (opens - closes)
    safe_check = re.sub(
        r"\b(sqrt|sin|cos|tan|log|exp|abs|pow|ceil|floor|pi|e)\b",
        "", cleaned).strip()
    if not re.match(r"^[\s0-9\.\+\-\*\/\%\(\)\^]+$",
                    safe_check if safe_check else "0"):
        result = (f"I couldn't parse '{expr[:60]}' as a math expression. "
                  "Please use numbers and operators like +, -, *, /.")
        speak(result); return result
    try:
        from sympy import sympify, N as _N
        result_val = _N(sympify(cleaned), 12)
        rs = str(result_val)
        if "." in rs:
            rs = rs.rstrip("0").rstrip(".")
        result = f"The answer is {rs}."; speak(result); return result
    except Exception:
        pass
    try:
        safe_ns = {
            "__builtins__": {},
            "sqrt": math.sqrt, "sin": math.sin, "cos": math.cos,
            "tan": math.tan, "log": math.log, "exp": math.exp,
            "abs": abs, "round": round, "pow": pow,
            "pi": math.pi, "e": math.e,
        }
        safe_expr = re.sub(r"[^0-9\+\-\*\/\(\)\.\s\%epi]", "", cleaned).strip()
        if safe_expr:
            result_val = eval(safe_expr, safe_ns)  # noqa: S307
            result = f"The answer is {result_val}."; speak(result); return result
    except Exception:
        pass
    result = f"I couldn't solve '{expr[:60]}'. Please check the expression."
    speak(result); return result



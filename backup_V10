def execute_command(text: str, intent: str) -> str:
    tl = text.lower().strip()
    if intent == "open_app":
        target = _strip(tl, ["open", "launch", "start", "run",
                               "please", "kholo", "chalu karo", "chalao"])
        return cmd_open_app(target)
    if intent == "open_setting":
        target = _strip(tl, ["open", "go to", "show", "settings", "setting"])
        return cmd_open_setting(target)
    if intent == "web_search":
        q = _strip(tl, ["search for", "search", "google", "find", "look up"])
        return cmd_web_search(q or text)
    if intent == "play_youtube":
        q = _strip(tl, ["play", "song", "gaana", "on youtube", "youtube"])
        return cmd_youtube(q or text)
    if intent == "screenshot":
        return cmd_screenshot()
    if intent == "record_screen":
        dur_m = re.search(r"(\d+)", tl)
        dur   = int(dur_m.group(1)) if dur_m else 10
        threading.Thread(target=_record_thread, args=(dur,), daemon=True).start()
        result = f"Screen recording started for {dur} seconds."
        speak(result); return result
    if intent == "system_ctrl":
        return cmd_system(tl)
    if intent == "math":
        expr = _strip(tl, ["calculate", "solve", "what is", "compute", "math"])
        return cmd_solve_math(expr or text)
    if intent == "date_time":
        return cmd_datetime(tl)
    if intent == "alarm":
        return cmd_alarm(tl)
    if intent == "ip_speed":
        if any(w in tl for w in ("speed", "download", "upload", "bandwidth")):
            threading.Thread(target=_speed_thread, daemon=True).start()
            result = "Running internet speed test, please wait…"
            speak(result); return result
        return cmd_ip()
    if intent == "selfie":
        threading.Thread(target=_selfie_thread, daemon=True).start()
        result = "Taking a photo with your webcam…"; speak(result); return result
    if intent == "system_info":
        if any(w in tl for w in ("ram", "memory", "mem")):
            return cmd_ram()
        if any(w in tl for w in ("processor", "cpu", "chip")):
            return cmd_cpu()
        if any(w in tl for w in ("storage", "disk", "drive", "space", "hard")):
            return cmd_storage()
        result = " | ".join([cmd_ram(), cmd_cpu(), cmd_storage()])
        speak(result); return result
    if intent == "network_info":
        if any(w in tl for w in ("gateway", "router", "default")):
            return cmd_gateway()
        if any(w in tl for w in ("mac", "physical", "hardware", "ethernet")):
            return cmd_mac()
        result = f"{cmd_gateway()}  {cmd_mac()}"
        speak(result); return result
    if intent == "weather":
        return cmd_weather(text)
    if intent == "news":
        return cmd_news(text)
    if intent == "api_manage":
        return _handle_api_command(text)
    return ""


def _rule_reply(text: str) -> Optional[str]:
    tl = text.lower().strip()
    for key, replies in REPLY_DB.items():
        if key in tl and replies:
            return random.choice(replies)
    keys = [k for k, v in REPLY_DB.items() if v]
    m    = get_close_matches(tl, keys, n=1, cutoff=0.62)
    if m:
        return random.choice(REPLY_DB[m[0]])
    return None



def _make_icon() -> QIcon:
    pix = QPixmap(32, 32); pix.fill(Qt.transparent)
    pp  = QPainter(pix); pp.setRenderHint(QPainter.Antialiasing)
    g = QRadialGradient(16, 16, 16)
    g.setColorAt(0, QColor(0, 220, 255)); g.setColorAt(1, QColor(0, 80, 160))
    pp.setBrush(QBrush(g)); pp.setPen(Qt.NoPen)
    pp.drawEllipse(0, 0, 32, 32)
    pp.setFont(QFont("Arial", 14, QFont.Bold)); pp.setPen(Qt.white)
    pp.drawText(pix.rect(), Qt.AlignCenter, "I"); pp.end()
    return QIcon(pix)


def _setup_tray(app: QApplication, win: ISHAWindow) -> QSystemTrayIcon:
    tray = QSystemTrayIcon(_make_icon(), app)
    tray.setToolTip("ISHA v10.0 — Intelligent Assistant | Ctrl+Alt+Space to focus")
    menu = QMenu()
    menu.setStyleSheet("""
        QMenu { background: #05080F; color: #00E5FF;
            border: 1px solid rgba(0,200,255,80); border-radius: 10px; padding: 4px; }
        QMenu::item { padding: 6px 18px; border-radius: 5px; }
        QMenu::item:selected { background: rgba(0,80,120,160); }
        QMenu::separator { height: 1px; background: rgba(0,180,240,50); margin: 3px 0; }
    """)
    for label, fn in [
        ("Show ISHA",      lambda: win.show()),
        ("Search",         lambda: (win.show(), win.search_bar.setFocus())),
        ("History",        lambda: (win.show(), win._open_history_manager())),
        ("Comm Dock",      lambda: (win.show(), win._toggle_comm_dock())),
        ("Screenshot",     lambda: win.respond(cmd_screenshot(), "isha")),
        (None, None),
        ("Exit",           app.quit),
    ]:
        if label is None:
            menu.addSeparator()
        else:
            a = QAction(label, menu); a.triggered.connect(fn); menu.addAction(a)
    tray.setContextMenu(menu)
    tray.activated.connect(
        lambda r: win.show() if r == QSystemTrayIcon.DoubleClick else None)
    tray.show()
    return tray



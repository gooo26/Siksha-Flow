def _self_install():
    """Quietly install missing pip packages and pull missing Ollama models."""
    print("[ISHA] Self-install check starting…")

    # ── 1. Pip packages ────────────────────────────────────────────────────
    for pkg in _PIP_PACKAGES:
        import_name = pkg.replace("-", "_").split("[")[0]
        # special-case name mismatches
        _import_map = {
            "PyQt5": "PyQt5",
            "edge_tts": "edge_tts",
            "SpeechRecognition": "speech_recognition",
            "beautifulsoup4": "bs4",
            "opencv_python": "cv2",
            "speedtest_cli": "speedtest",
            "pywhatkit": "pywhatkit",
        }
        import_name = _import_map.get(import_name, import_name)
        try:
            __import__(import_name)
        except ImportError:
            print(f"[INSTALL] Installing {pkg}…")
            try:
                subprocess.check_call(
                    [sys.executable, "-m", "pip", "install", pkg,
                     "--quiet", "--disable-pip-version-check"],
                    stdout=subprocess.DEVNULL,
                    stderr=subprocess.DEVNULL,
                )
                print(f"[INSTALL] {pkg} installed.")
            except Exception as e:
                print(f"[INSTALL] WARNING: could not install {pkg}: {e}")

    # ── 2. Ollama model puller ─────────────────────────────────────────────
    try:
        import ollama as _ol
        try:
            resp   = _ol.list()
            models = resp.models if hasattr(resp, "models") else resp.get("models", [])
            present = set()
            for m in models:
                name = (m.model if hasattr(m, "model") else
                        m.get("name", m.get("model", "")))
                present.add(name.split(":")[0])
        except Exception:
            present = set()

        for model in _OLLAMA_MODELS:
            base = model.split(":")[0]
            if base not in present:
                print(f"[INSTALL] Pulling Ollama model: {model} …")
                try:
                    for _chunk in _ol.pull(model, stream=True):
                        pass
                    print(f"[INSTALL] {model} ready.")
                except Exception as exc:
                    print(f"[INSTALL] WARNING: could not pull {model}: {exc}")
    except ImportError:
        print("[INSTALL] ollama package missing — model pull skipped.")

    print("[ISHA] Self-install check complete.")



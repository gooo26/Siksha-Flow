class _TFIDFVec:
    def __init__(self):
        self.vocab : Dict[str, int] = {}
        self._idf  : List[float]    = []
        self._N                     = 0
        self._df   : Dict[str, int] = {}

    @staticmethod
    def _tok(text: str) -> List[str]:
        return re.findall(r"[a-z0-9]+", text.lower())

    def fit(self, corpus: List[str]):
        self._N  = len(corpus)
        self._df = collections.Counter()
        freq     = collections.Counter()
        for doc in corpus:
            toks = self._tok(doc)
            freq.update(toks)
            self._df.update(set(toks))
        top = [w for w, _ in freq.most_common(900)]
        self.vocab = {w: i for i, w in enumerate(top)}
        self._idf  = [
            math.log((self._N + 1) / (self._df.get(w, 0) + 1)) + 1.0
            for w in top
        ]

    def vec(self, text: str) -> List[float]:
        toks  = collections.Counter(self._tok(text))
        total = max(sum(toks.values()), 1)
        v     = [0.0] * len(self.vocab)
        for w, c in toks.items():
            if w in self.vocab:
                v[self.vocab[w]] = (c / total) * self._idf[self.vocab[w]]
        norm = math.sqrt(sum(x * x for x in v)) or 1.0
        return [x / norm for x in v]

    @staticmethod
    def cosine(a: List[float], b: List[float]) -> float:
        return sum(x * y for x, y in zip(a, b))



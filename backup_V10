class _CmdWorker(QObject):
    result = pyqtSignal(str)

    def __init__(self):
        super().__init__()
        self._q  = queue.Queue()
        self._pt = QTimer(self)
        self._pt.timeout.connect(self._poll)
        self._pt.start(30)

    def enqueue(self, text: str):
        self._q.put(text)
        _comm_log(f"USER → {text[:80]}")

    def _poll(self):
        try:
            text = self._q.get_nowait()
        except queue.Empty:
            return
        threading.Thread(target=self._run, args=(text,), daemon=True).start()

    def _run(self, text: str):
        try:
            response = process_input(text)
        except Exception as exc:
            response = f"Something went wrong: {exc}"
            print(f"[ISHA ERROR] {exc}")
        if response:
            _comm_log(f"ISHA ◀ {response[:80]}")
            self.result.emit(response)



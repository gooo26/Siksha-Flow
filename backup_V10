class LocalAI:
    """
    v10 Triple-model Ollama pipeline.
    phi3:mini  → coding / analysis
    gemma2     → deep knowledge / explanation
    llama3.2   → general chat fallback

    Also supports cloud API routing when an active API config is set
    via the API Mode panel (see _ACTIVE_API_CONFIG).
    """

    CODER_MODEL = "phi3:mini"
    DEEP_MODEL  = "gemma2"
    CHAT_MODEL  = "llama3.2"

    def __init__(self):
        self._available = False
        self._lock      = threading.Lock()
        threading.Thread(target=self._probe, daemon=True,
                         name="ISHA-AIProbe").start()

    def _probe(self):
        try:
            import ollama as _ol
            resp = _ol.list()
            if hasattr(resp, "models"):
                models = resp.models
            elif isinstance(resp, dict):
                models = resp.get("models", [])
            else:
                models = list(resp) if resp else []
            with self._lock:
                self._available = True
            print(f"[AI] Ollama v10 ready — "
                  f"chat:{self.CHAT_MODEL} | deep:{self.DEEP_MODEL} "
                  f"| coder:{self.CODER_MODEL}")
        except ImportError:
            print("[AI] 'ollama' package not installed.")
        except Exception as exc:
            print(f"[AI] Ollama not available ({exc}). Offline mode.")

    @property
    def available(self) -> bool:
        with self._lock:
            return self._available

    def _pick_model(self, prompt: str) -> str:
        """
        Route to the best enabled model for the prompt.
        Respects the per-model ON/OFF toggle states set via Model Settings.
        Falls back through the priority chain if the ideal model is disabled.
        If ALL three ISHA models are disabled, tries any available Ollama model.
        """
        pl = prompt.lower()

        # Build preference order based on prompt keywords
        preferred: List[str] = []
        for kw in _CODING_KEYWORDS:
            if kw in pl:
                preferred = [self.CODER_MODEL, self.CHAT_MODEL, self.DEEP_MODEL]
                break
        if not preferred:
            for kw in _DEEP_KEYWORDS:
                if kw in pl:
                    preferred = [self.DEEP_MODEL, self.CHAT_MODEL, self.CODER_MODEL]
                    break
        if not preferred:
            preferred = [self.CHAT_MODEL, self.CODER_MODEL, self.DEEP_MODEL]

        # Return first enabled model in preference order
        for m in preferred:
            if is_model_enabled(m):
                return m

        # All three ISHA models are off — try any enabled Ollama model
        try:
            import ollama as _ol
            resp = _ol.list()
            models = resp.models if hasattr(resp, "models") else resp.get("models", [])
            for m in models:
                name = (m.model if hasattr(m, "model") else m.get("name", m.get("model", "")))
                if name and is_model_enabled(name):
                    return name
        except Exception:
            pass

        # Absolute last resort — use chat model regardless of toggle state
        return self.CHAT_MODEL

    def ask(self, prompt: str,
            history: Optional[List[dict]] = None) -> Optional[str]:
        # Cloud API override
        cloud_reply = _try_cloud_api(prompt, history)
        if cloud_reply is not None:
            return cloud_reply

        if not self.available:
            return None
        try:
            import ollama as _ol
        except ImportError:
            return None

        model   = self._pick_model(prompt)
        now_str = datetime.now().strftime("%A %d %B %Y, %I:%M %p")
        messages: List[dict] = [
            {
                "role": "system",
                "content": (
                    f"You are ISHA, a friendly, concise desktop AI assistant. "
                    f"Current date/time: {now_str}. "
                    f"Keep replies short (1-4 sentences) and natural. "
                    f"Do NOT use markdown, asterisks, bullet points, "
                    f"or any special formatting in your reply."
                ),
            }
        ]
        if history:
            messages.extend(history[-16:])
        messages.append({"role": "user", "content": prompt})

        try:
            resp = _ol.chat(model=model, messages=messages)
            if hasattr(resp, "message") and hasattr(resp.message, "content"):
                content = resp.message.content
            elif isinstance(resp, dict):
                content = resp.get("message", {}).get("content", "")
            else:
                content = str(resp)
            content = (content or "").strip()
            return content if content else None
        except Exception as exc:
            print(f"[AI] ollama.chat() error: {exc}")
            return (f"I'm having trouble reaching Ollama right now. "
                    f"Please ensure Ollama is running and '{model}' is pulled.")



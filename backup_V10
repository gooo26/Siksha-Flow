def _try_cloud_api(prompt: str,
                   history: Optional[List[dict]] = None) -> Optional[str]:
    """
    Attempt to route prompt to the first active cloud API config.
    Returns the response string, or None if no active config / on error.
    """
    actives = _get_active_api_configs()
    if not actives:
        return None

    cfg     = actives[0]
    vendor  = cfg.get("vendor", "")
    api_key = cfg.get("key", "")

    try:
        import requests

        if vendor == "OpenAI":
            r = requests.post(
                "https://api.openai.com/v1/chat/completions",
                headers={"Authorization": f"Bearer {api_key}",
                         "Content-Type": "application/json"},
                json={"model": "gpt-4o-mini",
                      "messages": [{"role": "user", "content": prompt}],
                      "max_tokens": 512},
                timeout=20)
            data = r.json()
            return data["choices"][0]["message"]["content"].strip()

        if vendor == "Google Gemini":
            r = requests.post(
                f"https://generativelanguage.googleapis.com/v1beta/"
                f"models/gemini-pro:generateContent?key={api_key}",
                json={"contents": [{"parts": [{"text": prompt}]}]},
                timeout=20)
            data = r.json()
            return (data.get("candidates", [{}])[0]
                    .get("content", {})
                    .get("parts", [{}])[0]
                    .get("text", "").strip())


class ModelSettingsPopup(QWidget):
    """
    Scans all installed Ollama models via ollama.list() and renders
    an ON/OFF toggle row for each one.  Changes update _MODEL_TOGGLES
    and _pick_model routing instantly and persistently.
    """

    def __init__(self, parent=None):
        super().__init__(parent, Qt.Tool | Qt.FramelessWindowHint | Qt.WindowStaysOnTopHint)
        self.setAttribute(Qt.WA_TranslucentBackground, True)
        self.setMinimumWidth(340)
        self.setSizePolicy(QSizePolicy.Preferred, QSizePolicy.Minimum)
        self._drag_pos  = None
        self._row_widgets: List[dict] = []
        self._build()
        self._load_models()

    # ── helpers ───────────────────────────────────────────────────────────

    def _scan_ollama_models(self) -> List[str]:
        """Return list of model name strings currently pulled in Ollama."""
        try:
            import ollama as _ol
            resp   = _ol.list()
            models = resp.models if hasattr(resp, "models") else resp.get("models", [])
            names  = []
            for m in models:
                name = (m.model if hasattr(m, "model") else
                        m.get("name", m.get("model", "")))
                if name:
                    names.append(name.strip())
            return sorted(set(names))
        except Exception:
            return []

    # ── build ─────────────────────────────────────────────────────────────

    def _build(self):
        root = QVBoxLayout(self)
        root.setContentsMargins(16, 16, 16, 16)
        root.setSpacing(8)

        # Header row
        hdr_row = QHBoxLayout()
        title = QLabel("⚙  Local Models Controller")
        title.setFont(QFont("Segoe UI Semibold", 11))
        title.setStyleSheet("color: #00F0FF; background: transparent;")
        hdr_row.addWidget(title)
        hdr_row.addStretch()

        refresh_btn = QPushButton("↻ Refresh")
        refresh_btn.setFixedSize(72, 24)
        refresh_btn.setStyleSheet("""
            QPushButton { background: rgba(0,40,60,200); color: #00D0F0;
                border: 1px solid rgba(0,180,240,70); border-radius: 6px; font-size: 8pt; }
            QPushButton:hover { background: rgba(0,70,100,220); }
        """)
        refresh_btn.setCursor(Qt.PointingHandCursor)
        refresh_btn.clicked.connect(self._load_models)
        hdr_row.addWidget(refresh_btn)

        close_btn = QPushButton("✕")
        close_btn.setFixedSize(24, 24)
        close_btn.setStyleSheet("""
            QPushButton { background: rgba(60,0,0,180); color: #FF4040;
                border: 1px solid rgba(255,60,60,70); border-radius: 6px; font-size: 9pt; }
            QPushButton:hover { background: rgba(100,0,0,220); }
        """)
        close_btn.setCursor(Qt.PointingHandCursor)
        close_btn.clicked.connect(self.hide)
        hdr_row.addWidget(close_btn)
        root.addLayout(hdr_row)

        sub = QLabel(
            "<span style=\'color:#304560; font-size:8pt;\'>"
            "Toggle any model ON/OFF — routing updates instantly.</span>")
        sub.setWordWrap(True)
        root.addWidget(sub)

        sep = QFrame(); sep.setFixedHeight(1)
        sep.setStyleSheet("background: rgba(0,200,255,50);")
        root.addWidget(sep)

        # Scrollable model list
        self._scroll = QScrollArea()
        self._scroll.setWidgetResizable(True)
        self._scroll.setMaximumHeight(320)
        self._scroll.setMinimumHeight(80)
        self._scroll.setStyleSheet("""
            QScrollArea { border: none; background: transparent; }
            QScrollBar:vertical { background: rgba(0,20,30,80); width: 4px; border-radius: 2px; }
            QScrollBar::handle:vertical { background: rgba(0,240,255,140); border-radius: 2px; }
            QScrollBar::add-line:vertical, QScrollBar::sub-line:vertical { height: 0; }
        """)
        self._list_widget = QWidget()
        self._list_widget.setStyleSheet("background: transparent;")
        self._list_lay = QVBoxLayout(self._list_widget)
        self._list_lay.setContentsMargins(0, 0, 0, 0)
        self._list_lay.setSpacing(6)
        self._list_lay.addStretch()
        self._scroll.setWidget(self._list_widget)
        root.addWidget(self._scroll)

        self._status_lbl = QLabel("")
        self._status_lbl.setFont(QFont("Segoe UI", 8))
        self._status_lbl.setStyleSheet("color: #304560; background: transparent;")
        self._status_lbl.setAlignment(Qt.AlignCenter)
        root.addWidget(self._status_lbl)

        self._root_lay = root

    def _load_models(self):
        """Scan Ollama and rebuild model rows."""
        # Clear existing rows (keep stretch at end)
        while self._list_lay.count() > 1:
            item = self._list_lay.takeAt(0)
            if item and item.widget():
                item.widget().deleteLater()
        self._row_widgets.clear()

        self._status_lbl.setText("Scanning Ollama models…")
        QApplication.processEvents()

        names = self._scan_ollama_models()

        if not names:
            placeholder = QLabel(
                "<span style=\'color:#304560; font-size:9pt;\'>"
                "No local Ollama models found.<br>"
                "Make sure Ollama is running and models are pulled.</span>")
            placeholder.setAlignment(Qt.AlignCenter)
            placeholder.setWordWrap(True)
            self._list_lay.insertWidget(0, placeholder)
            self._status_lbl.setText("Ollama not reachable or no models installed.")
            return

        for i, name in enumerate(names):
            row = self._make_model_row(name)
            self._list_lay.insertWidget(i, row)

        enabled_count = sum(1 for n in names if is_model_enabled(n))
        self._status_lbl.setText(
            f"{len(names)} model(s) found · {enabled_count} active")

        # Resize to content
        self.adjustSize()

    def _make_model_row(self, model_name: str) -> QWidget:
        """Create a single model row card with ON/OFF toggle."""
        enabled = is_model_enabled(model_name)

        card = QFrame()
        card.setStyleSheet("""
            QFrame {
                background: rgba(0,20,38,200);
                border: 1px solid rgba(0,180,255,60);
                border-radius: 9px;
            }
        """)
        card_lay = QHBoxLayout(card)
        card_lay.setContentsMargins(12, 7, 10, 7)
        card_lay.setSpacing(10)

        # Model name + tag
        info_lay = QVBoxLayout()
        info_lay.setSpacing(1)

        name_lbl = QLabel(f"<b style=\'color:#A0D8F0;\'>{model_name}</b>")
        info_lay.addWidget(name_lbl)

        # Tag known ISHA routing models
        tag = ""
        if model_name == LocalAI.CODER_MODEL:
            tag = "Coding / Analysis"
        elif model_name == LocalAI.DEEP_MODEL:
            tag = "Deep Knowledge"
        elif model_name == LocalAI.CHAT_MODEL:
            tag = "General Chat"
        if tag:
            tag_lbl = QLabel(
                f"<span style=\'color:#2A4860; font-size:7pt;\'>⬡ {tag}</span>")
            info_lay.addWidget(tag_lbl)

        card_lay.addLayout(info_lay, 1)

        # ON / OFF toggle button
        toggle_btn = QPushButton("ON" if enabled else "OFF")
        toggle_btn.setFixedSize(56, 28)
        toggle_btn.setCursor(Qt.PointingHandCursor)
        self._style_toggle(toggle_btn, enabled)

        def _on_toggle(btn=toggle_btn, mname=model_name):
            current = is_model_enabled(mname)
            new_state = not current
            set_model_enabled(mname, new_state)
            btn.setText("ON" if new_state else "OFF")
            self._style_toggle(btn, new_state)
            # Refresh status line
            all_names = [self._list_lay.itemAt(i).widget()
                         for i in range(self._list_lay.count() - 1)
                         if self._list_lay.itemAt(i) and
                         self._list_lay.itemAt(i).widget()]
            _comm_log(f"Model {mname} toggled {'ON' if new_state else 'OFF'}")
            enabled_c = len([k for k, v in _MODEL_TOGGLES.items() if v])
            self._status_lbl.setText(
                f"Model '{mname}' {'enabled' if new_state else 'disabled'}"
                f" — {enabled_c} active")

        toggle_btn.clicked.connect(_on_toggle)
        card_lay.addWidget(toggle_btn)

        return card

    @staticmethod
    def _style_toggle(btn: QPushButton, enabled: bool):
        if enabled:
            btn.setStyleSheet("""
                QPushButton {
                    background: qlineargradient(x1:0,y1:0,x2:0,y2:1,
                        stop:0 rgba(0,140,70,220), stop:1 rgba(0,100,50,220));
                    color: #00FF88; font-weight: bold; font-size: 9pt;
                    border: 1px solid rgba(0,220,100,120);
                    border-radius: 6px;
                }
                QPushButton:hover { background: rgba(0,160,80,240); }
            """)
        else:
            btn.setStyleSheet("""
                QPushButton {
                    background: qlineargradient(x1:0,y1:0,x2:0,y2:1,
                        stop:0 rgba(70,15,15,220), stop:1 rgba(50,10,10,220));
                    color: #FF5050; font-weight: bold; font-size: 9pt;
                    border: 1px solid rgba(220,60,60,100);
                    border-radius: 6px;
                }
                QPushButton:hover { background: rgba(90,20,20,240); }
            """)

    def paintEvent(self, e):
        p = QPainter(self); p.setRenderHint(QPainter.Antialiasing)
        W, H = self.width(), self.height()
        path = QPainterPath()
        path.addRoundedRect(QRectF(0, 0, W, H), 14, 14)
        bg = QLinearGradient(0, 0, W // 2, H)
        bg.setColorAt(0, QColor(4, 8, 20, 254))
        bg.setColorAt(1, QColor(8, 14, 36, 254))
        p.fillPath(path, QBrush(bg))
        p.setPen(QPen(QColor(0, 240, 255, 90), 1.5))
        p.setBrush(Qt.NoBrush); p.drawPath(path)
        # Corner HUD marks
        pen = QPen(QColor(0, 200, 255, 80), 1.2); p.setPen(pen)
        for (x, y, dx, dy) in [(1,1,12,0),(1,1,0,12),(W-1,1,-12,0),(W-1,1,0,12),
                                 (1,H-1,12,0),(1,H-1,0,-12),(W-1,H-1,-12,0),(W-1,H-1,0,-12)]:
            p.drawLine(x, y, x + dx, y + dy)

    def mousePressEvent(self, e):
        if e.button() == Qt.LeftButton:
            self._drag_pos = e.globalPos() - self.frameGeometry().topLeft()

    def mouseMoveEvent(self, e):
        if e.buttons() == Qt.LeftButton and self._drag_pos:
            self.move(e.globalPos() - self._drag_pos)

    def mouseReleaseEvent(self, e):
        self._drag_pos = None


class QuickSettingsPopup(QWidget):
    """
    v11: Uniform 3x2 grid (6 buttons, same size).
    Row 1: Mute | Display
    Row 2: Hand Control | API Mode
    Row 3: Model Settings | Chat History
    Removed: message bubble icon button from main bar.
    Dynamic sizing — no fixed height so buttons never get clipped.
    """

    # Uniform button cell dimensions
    _CELL_W = 126
    _CELL_H = 64

    def __init__(self, parent=None):
        super().__init__(parent, Qt.Tool | Qt.FramelessWindowHint | Qt.WindowStaysOnTopHint)
        self.setAttribute(Qt.WA_TranslucentBackground, True)
        self._is_open      = False
        self._apps_popup   : Optional[_LauncherPopup]     = None
        self._stgs_popup   : Optional[_LauncherPopup]     = None
        self._api_popup    : Optional[ApiModePopup]       = None
        self._model_popup  : Optional[ModelSettingsPopup] = None
        # history manager reference injected by ISHAWindow after construction
        self._hist_win_ref : Optional[Any] = None
        self._anim = QPropertyAnimation(self, b"windowOpacity")
        self._anim.setDuration(220); self._anim.setEasingCurve(QEasingCurve.OutCubic)
        self.setWindowOpacity(0.0)
        self._build()
        self.adjustSize()

    # ── show/hide ─────────────────────────────────────────────────────────

    def toggle(self, pos: QPoint):
        if self._is_open: self._do_hide()
        else:             self._do_show(pos)

    def _do_show(self, pos: QPoint):
        self.move(pos); self.setWindowOpacity(0.0); self.show()
        self._anim.stop()
        try: self._anim.finished.disconnect()
        except Exception: pass
        self._anim.setStartValue(0.0); self._anim.setEndValue(1.0); self._anim.start()
        self._is_open = True
        QTimer.singleShot(80, self._refresh_status)

    def _do_hide(self):
        self._anim.stop()
        try: self._anim.finished.disconnect()
        except Exception: pass
        self._anim.setStartValue(self.windowOpacity()); self._anim.setEndValue(0.0)
        self._anim.finished.connect(self._after_hide); self._anim.start()

    def _after_hide(self):
        self.hide(); self._is_open = False
        try: self._anim.finished.disconnect(self._after_hide)
        except Exception: pass

    # ── build ─────────────────────────────────────────────────────────────

    def _build(self):
        root = QVBoxLayout(self)
        root.setContentsMargins(16, 14, 16, 16)
        root.setSpacing(9)

        # ── Title ─────────────────────────────────────────────────────────
        hdr = QLabel("Quick Settings")
        hdr.setFont(QFont("Segoe UI Semibold", 11))
        hdr.setStyleSheet("color: #00F0FF; background: transparent;")
        root.addWidget(hdr, 0, Qt.AlignCenter)

        # ── Status labels ─────────────────────────────────────────────────
        self._ai_lbl = QLabel("● Local AI: checking…")
        self._ai_lbl.setFont(QFont("Segoe UI", 8))
        self._ai_lbl.setStyleSheet("color: #606890; background: transparent;")
        root.addWidget(self._ai_lbl, 0, Qt.AlignCenter)

        self._net_lbl = QLabel("◌ Network: checking…")
        self._net_lbl.setFont(QFont("Segoe UI", 8))
        self._net_lbl.setStyleSheet("color: #606890; background: transparent;")
        root.addWidget(self._net_lbl, 0, Qt.AlignCenter)

        QTimer.singleShot(3000, self._update_ai_label)
        QTimer.singleShot(1000, self._update_network_label)

        sep_top = QFrame(); sep_top.setFixedHeight(1)
        sep_top.setStyleSheet("background: rgba(0,200,255,40);")
        root.addWidget(sep_top)

        # ══ 3×2 UNIFORM GRID ══════════════════════════════════════════════
        from PyQt5.QtWidgets import QGridLayout
        grid = QGridLayout()
        grid.setSpacing(8)
        grid.setContentsMargins(0, 0, 0, 0)

        # All 6 cards get identical fixed size for a perfect uniform grid
        cw, ch = self._CELL_W, self._CELL_H

        # Row 0 — Mute | Display
        self._t_mute    = _ToggleCard("Mute",    "🔇")
        self._t_display = _ToggleCard("Display", "🖥")
        self._t_mute.setFixedSize(cw, ch)
        self._t_display.setFixedSize(cw, ch)
        self._t_mute.toggled.connect(self._do_mute)
        self._t_display.toggled.connect(self._do_display)
        grid.addWidget(self._t_mute,    0, 0)
        grid.addWidget(self._t_display, 0, 1)

        # Row 1 — Hand Control | API Mode
        self._t_hand_control = _ToggleCard("Hand", "🤚")
        self._t_hand_control.setFixedSize(cw, ch)
        self._t_hand_control.setToolTip(
            "Toggle MediaPipe hand gesture engine\n"
            "Pinch=Click  |  Fist=Screenshot  |  2-finger scroll")
        self._t_hand_control.toggled.connect(self._do_hand_control)

        self._t_api_mode = _ToggleCard("API Mode", "🌐")
        self._t_api_mode.setFixedSize(cw, ch)
        self._t_api_mode.setToolTip(
            "Manage cloud API configurations.\n"
            "When ON, routes prompts to active cloud API.")
        self._t_api_mode.toggled.connect(self._do_api_mode)

        grid.addWidget(self._t_hand_control, 1, 0)
        grid.addWidget(self._t_api_mode,     1, 1)

        # Row 2 — Model Settings | Chat History  (NEW)
        self._t_model_settings = _ToggleCard("Models", "🤖")
        self._t_model_settings.setFixedSize(cw, ch)
        self._t_model_settings.setToolTip(
            "Open Local Models Controller\n"
            "Enable/disable individual Ollama models for routing.")
        self._t_model_settings.toggled.connect(self._do_model_settings)

        self._t_chat_history = _ToggleCard("History", "💬")
        self._t_chat_history.setFixedSize(cw, ch)

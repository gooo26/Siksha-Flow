class ISHAClassifier:
    def __init__(self):
        self._tfidf  = _TFIDFVec()
        self._corpus : List[str] = []
        self._labels : List[str] = []
        self._vecs   : List[List[float]] = []
        self._build(_TRAIN)

    def _build(self, corpus_dict: Dict[str, List[str]]):
        texts, labels = [], []
        for intent, examples in corpus_dict.items():
            for ex in examples:
                texts.append(ex)
                labels.append(intent)
        self._corpus = texts
        self._labels = labels
        self._tfidf.fit(texts)
        self._vecs = [self._tfidf.vec(t) for t in texts]

    def add_example(self, text: str, intent: str):
        self._corpus.append(text.lower())
        self._labels.append(intent)
        self._vecs.append(self._tfidf.vec(text.lower()))

    def predict(self, text: str) -> Tuple[str, float]:
        if not self._vecs:
            return "chat", 0.0
        qv = self._tfidf.vec(text.lower())
        best, best_intent = -1.0, "chat"
        for v, lbl in zip(self._vecs, self._labels):
            s = _TFIDFVec.cosine(qv, v)
            if s > best:
                best, best_intent = s, lbl
        return (best_intent, best) if best >= 0.20 else ("chat", best)


